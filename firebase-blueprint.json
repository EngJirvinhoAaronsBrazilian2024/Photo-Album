{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the family photo album app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "avatarUrl": { "type": "string", "description": "URL to the user's avatar image." },
        "createdAt": { "type": "timestamp", "description": "When the user was created." }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Album": {
      "title": "Album",
      "description": "A collection of family photos.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the album." },
        "date": { "type": "string", "description": "The date or date range of the album." },
        "coverUrl": { "type": "string", "description": "URL to the album's cover image." },
        "photoCount": { "type": "number", "description": "Number of photos in the album." },
        "ownerId": { "type": "string", "description": "The UID of the user who created the album." },
        "createdAt": { "type": "timestamp", "description": "When the album was created." }
      },
      "required": ["title", "date", "coverUrl", "photoCount", "ownerId", "createdAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "A single photo in an album.",
      "type": "object",
      "properties": {
        "albumId": { "type": "string", "description": "The ID of the album this photo belongs to." },
        "url": { "type": "string", "description": "URL to the photo image." },
        "caption": { "type": "string", "description": "Caption for the photo." },
        "date": { "type": "string", "description": "Date the photo was taken or uploaded." },
        "likes": { "type": "number", "description": "Number of likes." },
        "comments": { "type": "number", "description": "Number of comments." },
        "authorId": { "type": "string", "description": "The UID of the user who uploaded the photo." },
        "authorName": { "type": "string", "description": "The name of the user who uploaded the photo." },
        "authorAvatarUrl": { "type": "string", "description": "The avatar URL of the user who uploaded the photo." },
        "createdAt": { "type": "timestamp", "description": "When the photo was uploaded." }
      },
      "required": ["albumId", "url", "caption", "date", "likes", "comments", "authorId", "authorName", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a photo.",
      "type": "object",
      "properties": {
        "photoId": { "type": "string", "description": "The ID of the photo this comment belongs to." },
        "text": { "type": "string", "description": "The text of the comment." },
        "authorId": { "type": "string", "description": "The UID of the user who wrote the comment." },
        "authorName": { "type": "string", "description": "The name of the user who wrote the comment." },
        "authorAvatarUrl": { "type": "string", "description": "The avatar URL of the user who wrote the comment." },
        "createdAt": { "type": "timestamp", "description": "When the comment was created." }
      },
      "required": ["photoId", "text", "authorId", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/albums/{albumId}": {
      "schema": { "$ref": "#/entities/Album" },
      "description": "Stores family albums."
    },
    "/photos/{photoId}": {
      "schema": { "$ref": "#/entities/Photo" },
      "description": "Stores photos."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments on photos."
    }
  }
}
